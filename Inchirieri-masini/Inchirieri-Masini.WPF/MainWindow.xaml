<Window x:Class="InchirieriMasini.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Închiriere"
        Width="600"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Background="#D6EAF8"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- Stil global pentru Label -->
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1B4F72"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Stil pentru butoane moderne -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Background" Value="#5DADE2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <!-- Stânga: formular -->
            <ColumnDefinition Width="1*" />
            <!-- Dreapta: tabel -->
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!--      FORMULAR CLIENT      -->
        <!-- ========================= -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" Margin="0 20">

                <Border Background="#AED6F1"
                    CornerRadius="15"
                    Padding="25"
                    Width="380"
                    Margin="0 20"
                    BorderBrush="#5DADE2"
                    BorderThickness="2">

                    <StackPanel>

                        <Label Content="Adaugă Client Nou"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#154360"
                           Margin="0 0 0 15"/>

                        <!-- NUME -->
                        <Label x:Name="LblNume" Content="Nume"/>
                        <TextBox x:Name="TxtNume"/>
                        <TextBlock x:Name="ErrNume" Foreground="Red" Visibility="Collapsed"/>

                        <!-- PRENUME -->
                        <Label x:Name="LblPrenume" Content="Prenume"/>
                        <TextBox x:Name="TxtPrenume"/>
                        <TextBlock x:Name="ErrPrenume" Foreground="Red" Visibility="Collapsed"/>

                        <!-- CNP -->
                        <Label x:Name="LblCNP" Content="CNP"/>
                        <TextBox x:Name="TxtCNP"/>
                        <TextBlock x:Name="ErrCNP" Foreground="Red" Visibility="Collapsed"/>

                        <Separator Margin="0 10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Adaugă" Click="OnAddClient"/>
                            <Button Content="Reset" Background="#3498DB" Click="OnResetClient"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ========================= -->
        <!--        TABEL CLIENTI      -->
        <!-- ========================= -->
        <StackPanel Grid.Column="1" Margin="20">

            <Label Content="Lista Clienților"
               FontSize="22"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Foreground="#154360"
               Margin="0 0 0 15"/>

            <DataGrid x:Name="DataGridClienti"
                  AutoGenerateColumns="True"
                  Background="White"
                  Foreground="Black"
                  FontSize="14"
                  Margin="0 10"
                  Height="350"
                  Width="420"
                  IsReadOnly="True"/>
        </StackPanel>

    </Grid>



</Window>

    