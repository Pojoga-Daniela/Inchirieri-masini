<Window x:Class="InchirieriMasini.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Închiriere"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#D6EAF8"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- ========================= -->
        <!--        CULORI GLOBALE     -->
        <!-- ========================= -->
        <Color x:Key="PrimaryColor">#5DADE2</Color>
        <Color x:Key="PrimaryDark">#1B4F72</Color>
        <Color x:Key="PrimaryLight">#D6EAF8</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>

        <!-- ========================= -->
        <!--        LABEL STYLE         -->
        <!-- ========================= -->
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- ========================= -->
        <!--        TEXTBOX STYLE       -->
        <!-- ========================= -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ========================= -->
        <!--        BUTTON STYLE        -->
        <!-- ========================= -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================= -->
        <!--     RADIOBUTTON STYLE     -->
        <!-- ========================= -->
        <Style TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- ========================= -->
        <!--      CHECKBOX STYLE       -->
        <!-- ========================= -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- ========================= -->
        <!--      DATAGRID STYLE       -->
        <!-- ========================= -->
        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F2F2F2"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

    </Window.Resources>



    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Meniu -->
            <RowDefinition/>
            <!-- Conținut -->
        </Grid.RowDefinitions>


        <!-- MENIU -->
        <Menu Grid.Row="0" Background="#5DADE2" Foreground="Black" FontSize="16">
            <MenuItem Header="Fișier">
                <MenuItem Header="Ieșire" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="Client">
                <MenuItem Header="Adaugă Client" Click="OnMenuAddClient"/>
                <MenuItem Header="Caută Client" Click="OnMenuSearchClient"/>
            </MenuItem>
            <MenuItem Header="Ajutor">
                <MenuItem Header="Despre" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <!-- ========================= -->
        <!--      FORMULAR CLIENT      -->
        <!-- ========================= -->
        <Grid Grid.Row="1" x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="ScrollViewerFormular" Grid.Column="0" Grid.Row="0" VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="StackPanelTabel" Grid.Column="1" Grid.Row="0" Margin="20">


                    <Border Background="#AED6F1"
                    CornerRadius="15"
                    Padding="25"
                    Width="380"
                    Margin="0 20"
                    BorderBrush="#5DADE2"
                    BorderThickness="2">

                        <StackPanel>

                            <Label Content="Adaugă Client Nou"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#154360"
                           Margin="0 0 0 15"/>

                            <!-- NUME -->
                            <Label x:Name="LblNume" Content="Nume"/>
                            <TextBox x:Name="TxtNume"/>
                            <TextBlock x:Name="ErrNume" Foreground="Red" Visibility="Collapsed"/>

                            <!-- PRENUME -->
                            <Label x:Name="LblPrenume" Content="Prenume"/>
                            <TextBox x:Name="TxtPrenume"/>
                            <TextBlock x:Name="ErrPrenume" Foreground="Red" Visibility="Collapsed"/>

                            <!-- CNP -->
                            <Label x:Name="LblCNP" Content="CNP"/>
                            <TextBox x:Name="TxtCNP"/>
                            <TextBlock x:Name="ErrCNP" Foreground="Red" Visibility="Collapsed"/>

                            <!-- GEN -->
                            <Label Content="Gen"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbFeminin" Content="Feminin" Margin="5"/>
                                <RadioButton x:Name="RbMasculin" Content="Masculin" Margin="5"/>
                            </StackPanel>

                            <!-- NEWSLETTER -->
                            <CheckBox x:Name="CbNewsletter" Content="Abonare la newsletter" Margin="5"/>


                            <Separator Margin="0 10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Adaugă" Click="OnAddClient"/>
                                <Button Content="Reset" Background="#3498DB" Click="OnResetClient"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ========================= -->
            <!--        TABEL CLIENTI      -->
            <!-- ========================= -->
            <StackPanel Grid.Column="1" Margin="20">

                <Label Content="Lista Clienților"
               FontSize="22"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Foreground="#154360"
               Margin="0 0 0 15"/>

                <!-- CĂUTARE CLIENT -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                    <TextBox x:Name="TxtCauta"
                 Width="200"
                 Height="30"
                 Margin="0 0 10 0"/>
                    <Button Content="Caută" Width="80" Click="OnCautaClient"/>
                    <Button Content="Reset" Width="80" Background="#3498DB" Click="OnResetCautare"/>
                </StackPanel>





                <DataGrid x:Name="DataGridClienti"
                          AutoGenerateColumns="False"
                          Background="White"
                          Foreground="Black"
                          FontSize="14"
                          Margin="0 10"
                          Height="350"
                          Width="420"
                          IsReadOnly="True">    

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                        <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="*"/>
                        <DataGridTextColumn Header="CNP" Binding="{Binding CNP}" Width="*"/>

                        <!-- GEN -->
                        <DataGridTextColumn Header="Gen" Binding="{Binding Gen}" Width="*"/>

                        <!-- ABONAT -->
                        <DataGridTextColumn Header="Abonat" Binding="{Binding Abonat}" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>



            </StackPanel>

        </Grid>

    </Grid>

</Window>