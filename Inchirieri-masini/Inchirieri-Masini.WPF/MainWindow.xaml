<Window x:Class="InchirieriMasini.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Închiriere"
        Width="600"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Background="#D6EAF8"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>

        <!-- Stil global pentru Label -->
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1B4F72"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Stil pentru butoane moderne -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Background" Value="#5DADE2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- CARD principal -->
        <Border Background="#AED6F1"
                CornerRadius="15"
                Padding="25"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#5DADE2"
                BorderThickness="2">

            <StackPanel>

                <!-- Titlu -->
                <Label Content="Detalii Închiriere"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#154360"
                       Margin="0 0 0 15"/>

                <!-- Informații -->
                <Label Name="lblClient" FontSize="18" FontWeight="Bold"/>
                <Label Name="lblMasina"/>
                <Label Name="lblPerioada"/>

                <!-- Linie de separare -->
                <Separator Margin="0 15"/>

                <!-- Butoane -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Confirmă"/>
                    <Button Content="Anulează" Background="#3498DB"/>
                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>

    